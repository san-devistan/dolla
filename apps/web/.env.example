# Optional. Set when apps/web uses the Convex backend.
VITE_CONVEX_URL=https://<deployment>.convex.cloud

# Server-side media sync also reads CONVEX_URL when available.
CONVEX_URL=https://<deployment>.convex.cloud

# Server-only. Required for /admin/* routes.
ADMIN_SECRET=<admin-secret>

# Server-only. Required for the Cloudinary admin surface.
# Do not prefix API secrets with VITE_.
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# Alternative to the three values above:
# CLOUDINARY_URL=cloudinary://<api-key>:<api-secret>@<cloud-name>
